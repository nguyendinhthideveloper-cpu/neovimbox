# https://editorconfig.org — consistent style across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Don't touch trailing whitespace in markdown (2 trailing spaces = line break)
[*.md]
trim_trailing_whitespace = false
